{
  "openapi": "3.1.0",
  "info": {
    "title": "Darpan JSON-RPC API",
    "description": "OpenAPI wrapper for Darpan's Moqui JSON-RPC endpoint. All Darpan calls share this transport: POST a JSON-RPC 2.0 envelope to /rpc/json with a verified facade service name in `method`. The verified method catalog is on the Service catalog page of this reference.",
    "version": "2.1"
  },
  "servers": [
    {
      "url": "https://{darpanHost}",
      "description": "Assigned Darpan backend",
      "variables": {
        "darpanHost": {
          "default": "darpan.example.com",
          "description": "Darpan host for the target environment"
        }
      }
    }
  ],
  "security": [
    {
      "csrfToken": []
    }
  ],
  "paths": {
    "/rpc/json": {
      "post": {
        "summary": "Call a Darpan service",
        "description": "Submit a JSON-RPC request to a Darpan backend service. Authentication is session-cookie based and most calls require a valid CSRF token.",
        "operationId": "callDarpanJsonRpcService",
        "tags": [
          "JSON-RPC"
        ],
        "requestBody": {
          "description": "JSON-RPC request with a Moqui service name in `method` and service inputs in `params`.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JsonRpcRequest"
              },
              "examples": {
                "loginSession": {
                  "summary": "Log in and create a session",
                  "value": {
                    "jsonrpc": "2.0",
                    "id": 1,
                    "method": "facade.AuthFacadeServices.login#Session",
                    "params": {
                      "username": "<username>",
                      "password": "<password>"
                    }
                  }
                },
                "sessionInfo": {
                  "summary": "Get current session information",
                  "value": {
                    "jsonrpc": "2.0",
                    "id": 2,
                    "method": "facade.AuthFacadeServices.get#SessionInfo",
                    "params": {}
                  }
                },
                "listSavedRuns": {
                  "summary": "List saved reconciliation runs",
                  "value": {
                    "jsonrpc": "2.0",
                    "id": 3,
                    "method": "facade.ReconciliationFacadeServices.list#SavedRuns",
                    "params": {
                      "query": "",
                      "pageIndex": 0,
                      "pageSize": 20
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JSON-RPC success or service-level error envelope.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/JsonRpcSuccess"
                    },
                    {
                      "$ref": "#/components/schemas/JsonRpcError"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "The session is missing, expired, or not authorized for the requested service."
          },
          "403": {
            "description": "The request is missing a required CSRF token or the user lacks permission."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "JsonRpcRequest": {
        "type": "object",
        "required": [
          "jsonrpc",
          "id",
          "method",
          "params"
        ],
        "properties": {
          "jsonrpc": {
            "type": "string",
            "const": "2.0"
          },
          "id": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              }
            ]
          },
          "method": {
            "type": "string",
            "description": "Moqui service name, for example `facade.AuthFacadeServices.get#SessionInfo`."
          },
          "params": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "JsonRpcSuccess": {
        "type": "object",
        "required": [
          "jsonrpc",
          "id",
          "result"
        ],
        "properties": {
          "jsonrpc": {
            "type": "string"
          },
          "id": {},
          "result": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "JsonRpcError": {
        "type": "object",
        "required": [
          "jsonrpc",
          "id",
          "error"
        ],
        "properties": {
          "jsonrpc": {
            "type": "string"
          },
          "id": {},
          "error": {
            "type": "object",
            "required": [
              "code",
              "message"
            ],
            "properties": {
              "code": {
                "type": "integer"
              },
              "message": {
                "type": "string"
              },
              "data": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "csrfToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-CSRF-Token",
        "description": "CSRF token returned by the backend login/session flow."
      }
    }
  }
}
